<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key>
  <string>RamaTransparentProxyExampleExtension</string>
  <key>CFBundleIdentifier</key>
  <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>CFBundleExecutable</key>
  <string>$(EXECUTABLE_NAME)</string>
  <key>CFBundleShortVersionString</key>
  <string>$(MARKETING_VERSION)</string>
  <key>CFBundleVersion</key>
  <string>$(CURRENT_PROJECT_VERSION)</string>
  <key>CFBundlePackageType</key>
  <string>SYSX</string>
  <key>LSMinimumSystemVersion</key>
  <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
  <key>NSSystemExtensionUsageDescription</key>
  <string>Installs the transparent proxy system extension used by the demo.</string>
  <key>NetworkExtension</key>
  <dict>
    <key>NEProviderClasses</key>
    <dict>
      <key>com.apple.networkextension.app-proxy</key>
      <string>RamaAppleNetworkExtension.RamaTransparentProxyProvider</string>
    </dict>
    <!-- Version suffix works around Apple FB21271237: when a sysext is
         replaced by a new build, launchd's `MachServices` table is not
         refreshed until the next reboot, so the container's
         `xpc_connection_create_mach_service(NEMachServiceName)` lookup
         fails (`xpc_error=[3: No such process]`) until reboot.
         Embedding `$(CURRENT_PROJECT_VERSION)` makes every build use a
         unique mach name so each new install gets a fresh launchd
         registration. The container reads the same composed name from
         its own Info.plist — they must stay in sync. -->
    <key>NEMachServiceName</key>
    <string>$(APP_GROUP_ID).provider.$(CURRENT_PROJECT_VERSION)</string>
  </dict>
</dict>
</plist>
